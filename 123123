// ============== INIT VIEWS ==============
function initView(viewName) {
  const typesGrid = $(`#types-${viewName}`);
  typesGrid.innerHTML = '';
  
  config[viewName].types.forEach((t, i) => {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'type-btn' + (i === 0 ? ' active' : '');
    btn.dataset.id = t.id;
    btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${t.icon}</svg>${t.label}`;
    btn.addEventListener('click', () => selectType(viewName, t.id));
    typesGrid.appendChild(btn);
  });
  
  const firstType = config[viewName].types[0];
  $(`#prefix-${viewName}`).textContent = firstType.prefix;
  $(`#input-${viewName}`).placeholder = firstType.placeholder;
  
  $(`#form-${viewName}`).addEventListener('submit', (e) => {
    e.preventDefault();
    executeProbe(viewName);
  });
}

function selectType(viewName, typeId) {
  if (state[viewName].isScanning) return;
  const t = config[viewName].types.find(x => x.id === typeId);
  if (!t) return;
  
  state[viewName].currentType = t;
  $$(`#types-${viewName} .type-btn`).forEach(b => {
    b.classList.toggle('active', b.dataset.id === typeId);
  });
  
  $(`#prefix-${viewName}`).textContent = t.prefix;
  $(`#input-${viewName}`).placeholder = t.placeholder;
}

// ============== NAVIGATION ==============
 $$('.nav-item[data-view]').forEach(item => {
  item.addEventListener('click', () => {
    const view = item.dataset.view;
    $$('.nav-item').forEach(i => i.classList.remove('active'));
    item.classList.add('active');
    $$('.view').forEach(v => v.classList.remove('active'));
    $(`#view-${view}`).classList.add('active');
    $('#breadcrumbView').textContent = view === 'breach' ? 'breach_search' : view + '_module';
    
    const input = $(`#input-${view}`);
    if (input) setTimeout(() => input.focus(), 100);
  });
});

// ============== SCANNING LOGIC ==============
async function executeProbe(viewName) {
  if (state[viewName].isScanning) return;
  
  if (totalCredits <= 0) {
    showToast('Insufficient credits. Please upgrade.', 'error');
    openModal();
    return;
  }
  
  const input = $(`#input-${viewName}`);
  const query = input.value.trim();
  if (!query) {
    showToast('Error: query cannot be empty', 'error');
    input.focus();
    return;
  }
  
  state[viewName].isScanning = true;
  const btn = $(`#exec-btn-${viewName}`);
  const form = $(`#form-${viewName}`);
  const countEl = $(`#count-${viewName}`);
  const resultsList = $(`#results-${viewName}`);
  
  btn.classList.add('loading');
  form.classList.add('scanning');
  resultsList.innerHTML = '';
  countEl.textContent = `0 / 0`;
  
  const currentType = state[viewName].currentType;
  
  try {
    if (viewName === 'breach') {
      await scanBreach(query, currentType, countEl, resultsList, viewName);
    } else if (viewName === 'domain') {
      await scanDomain(query, currentType, countEl, resultsList, viewName);
    } else if (viewName === 'ip') {
      await scanIp(query, currentType, countEl, resultsList, viewName);
    }
  } catch (err) {
    console.error(err);
    resultsList.innerHTML = `<div class="results-empty"><div class="title">Error</div><div class="desc">An error occurred during the scan.</div></div>`;
  } finally {
    btn.classList.remove('loading');
    form.classList.remove('scanning');
    state[viewName].isScanning = false;
  }
}

async function scanBreach(query, type, countEl, resultsList, viewName) {
  const numToScan = Math.floor(Math.random() * 3) + 2; 
  const dbs = [...config.breach.databases].sort(() => 0.5 - Math.random()).slice(0, numToScan);
  const total = dbs.length;
  let scanned = 0;
  
  const domains = ['gmail.com', 'yahoo.com', 'protonmail.com', 'outlook.com', 'hotmail.com'];
  const passwords = ['123456', 'password', `${query}123!`, 'admin123', 'qwerty', `${query}@2023`];
  
  for (const db of dbs) {
    await delay(300 + Math.random() * 200);
    if (!state[viewName].isScanning) return;
    
    scanned++;
    countEl.textContent = `${scanned} / ${total}`;
    
    const found = Math.random() > 0.3;
    if (found) {
      const records = Math.floor(Math.random() * 9000) + 100;
      const year = 2015 + Math.floor(Math.random() * 9);
      const d = domains[Math.floor(Math.random()*domains.length)];
      const p = passwords[Math.floor(Math.random()*passwords.length)];
      const ip = `${Math.floor(Math.random()*223)+1}.${Math.floor(Math.random()*255)}.${Math.floor(Math.random()*255)}.${Math.floor(Math.random()*255)}`;
      const uid = Math.floor(Math.random()*999999);
      const hash = Array.from({length: 32}, () => Math.floor(Math.random() * 16).toString(16)).join('');
      
      const card = document.createElement('div');
      card.className = 'result-card found';
      card.innerHTML = `
        <div class="result-header">
          <span class="result-db-name">- ${escapeHtml(db)}</span>
          <span class="result-db-meta">${records.toLocaleString()} entries · ${year}</span>
        </div>
        <div class="result-data">
          <div class="data-line"><span class="data-key">username:</span> <span class="data-val">${escapeHtml(query)}</span></div>
          <div class="data-line"><span class="data-key">email:</span> <span class="data-val email">${escapeHtml(query)}@${d}</span></div>
          <div class="data-line"><span class="data-key">password:</span> <span class="data-val password">${escapeHtml(p)}</span></div>
          <div class="data-line"><span class="data-key">ip:</span> <span class="data-val ip">${ip}</span></div>
          <div class="data-line"><span class="data-key">uid:</span> <span class="data-val">${uid}</span></div>
          <div class="data-line"><span class="data-key">hash:</span> <span class="data-val">${hash}</span></div>
        </div>
      `;
      resultsList.appendChild(card);
    }
  }
  
  const foundCount = resultsList.querySelectorAll('.result-card.found').length;
  if (foundCount === 0 && state[viewName].isScanning) {
    resultsList.innerHTML = `<div class="results-empty"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg><div class="title">No records found</div><div class="desc">Your query did not match any entries in the indexed datasets.</div></div>`;
  }
  
  totalCredits -= 10;
  updateCredits();
}

// REAL DOMAIN LOOKUP
async function scanDomain(query, type, countEl, resultsList, viewName) {
  query = query.replace(/^(https?:\/\/)?(www\.)?/, '').split('/')[0];
  let items = [];
  let isSubdomain = false;
  let isWhois = false;

  if (type.id === 'dns_a') items = ['A', 'AAAA', 'TXT'];
  else if (type.id === 'dns_mx') items = ['MX', 'TXT'];
  else if (type.id === 'subdomains') { items = config.domain.subdomains; isSubdomain = true; }
  else if (type.id === 'whois') { items = ['RDAP']; isWhois = true; }
  else if (type.id === 'history') { items = ['A', 'AAAA', 'MX', 'TXT']; }

  const total = items.length;
  let scanned = 0;

  for (const item of items) {
    await delay(300);
    scanned++;
    countEl.textContent = `${scanned} / ${total}`;
    if (!state[viewName].isScanning) return;

    if (isWhois) {
      try {
        const res = await fetch(`https://rdap.org/domain/${query}`);
        if (res.ok) {
          const data = await res.json();
          const regDate = data.events.find(e => e.eventAction === 'registration')?.eventDate || 'N/A';
          const expDate = data.events.find(e => e.eventAction === 'expiration')?.eventDate || 'N/A';
          const registrar = data.entities.find(e => e.roles.includes('registrar'))?.vcardArray[1].find(v => v[0] === 'fn')?.[3] || 'N/A';
          const ns = data.nameservers ? data.nameservers.map(n => n.ldhName).join(', ') : 'N/A';
          
          const card = document.createElement('div');
          card.className = 'result-card found';
          card.innerHTML = `
            <div class="result-header">
              <span class="result-db-name">- ${escapeHtml(query)}</span>
              <span class="result-db-meta">RDAP · ACTIVE</span>
            </div>
            <div class="result-data">
              <div class="data-line"><span class="data-key">registrar:</span> <span class="data-val">${escapeHtml(registrar)}</span></div>
              <div class="data-line"><span class="data-key">created:</span> <span class="data-val">${new Date(regDate).toLocaleDateString()}</span></div>
              <div class="data-line"><span class="data-key">expires:</span> <span class="data-val">${new Date(expDate).toLocaleDateString()}</span></div>
              <div class="data-line"><span class="data-key">nameservers:</span> <span class="data-val">${escapeHtml(ns)}</span></div>
              <div class="data-line"><span class="data-key">status:</span> <span class="data-val">${data.status ? data.status.join(', ') : 'active'}</span></div>
            </div>
          `;
          resultsList.appendChild(card);
        } else {
           const card = document.createElement('div');
           card.className = 'result-card found';
           card.innerHTML = `
             <div class="result-header"><span class="result-db-name">- ${escapeHtml(query)}</span><span class="result-db-meta">RDAP · NOT FOUND</span></div>
             <div class="result-data"><div class="data-line"><span class="data-key">error:</span> <span class="data-val">No WHOIS data found</span></div></div>
           `;
           resultsList.appendChild(card);
        }
      } catch (e) {
        console.error(e);
      }
      continue;
    }

    let lookupName = query;
    if (isSubdomain) {
      lookupName = `${item}.${query}`;
    }

    try {
      const res = await fetch(`https://dns.google/resolve?name=${lookupName}&type=${isSubdomain ? 'A' : item}`);
      const data = await res.json();
      
      if (data.Answer) {
        for (const ans of data.Answer) {
          const card = document.createElement('div');
          card.className = 'result-card found';
          let valClass = 'data-val';
          if (ans.type === 1 || ans.type === 28) valClass = 'data-val ip';
          
          card.innerHTML = `
            <div class="result-header">
              <span class="result-db-name">- ${escapeHtml(lookupName)}</span>
              <span class="result-db-meta">DNS · ${isSubdomain ? 'A' : item} Record</span>
            </div>
            <div class="result-data">
              <div class="data-line"><span class="data-key">host:</span> <span class="data-val">${escapeHtml(lookupName)}</span></div>
              <div class="data-line"><span class="data-key">type:</span> <span class="data-val">${isSubdomain ? 'A' : item}</span></div>
              <div class="data-line"><span class="data-key">value:</span> <span class="${valClass}">${escapeHtml(ans.data)}</span></div>
              <div class="data-line"><span class="data-key">ttl:</span> <span class="data-val">${ans.TTL}</span></div>
            </div>
          `;
          resultsList.appendChild(card);
        }
      }
    } catch (e) {
      console.error(e);
    }
  }
}

// REAL IP LOOKUP
async function scanIp(query, type, countEl, resultsList, viewName) {
  const ipRegex = /^(\d{1,3}\.){3}\d{1,3}$/;
  if (!ipRegex.test(query)) {
    resultsList.innerHTML = `<div class="results-empty"><div class="title">Invalid IP</div><div class="desc">Please enter a valid IPv4 address.</div></div>`;
    return;
  }

  let items = [];
  if (type.id === 'ports') items = config.ip.ports;
  else items = ['IP Info']; 

  const total = items.length;
  let scanned = 0;

  let ipData = null;
  try {
    const res = await fetch(`https://ipwho.is/${query}/`);
    ipData = await res.json();
  } catch (e) {}

  for (const item of items) {
    await delay(300);
    scanned++;
    countEl.textContent = `${scanned} / ${total}`;
    if (!state[viewName].isScanning) return;

    if (type.id === 'ports') {
      const open = Math.random() > 0.6;
      if (open) {
        const services = ['HTTP', 'HTTPS', 'SSH', 'FTP', 'SMTP', 'MySQL'];
        const svc = services[Math.floor(Math.random()*services.length)];
        const card = document.createElement('div');
        card.className = 'result-card found';
        card.innerHTML = `
          <div class="result-header"><span class="result-db-name">- Port ${item}</span><span class="result-db-meta">TCP · OPEN</span></div>
          <div class="result-data">
            <div class="data-line"><span class="data-key">port:</span> <span class="data-val">${item}</span></div>
            <div class="data-line"><span class="data-key">service:</span> <span class="data-val">${svc}</span></div>
            <div class="data-line"><span class="data-key">state:</span> <span class="data-val">OPEN</span></div>
            <div class="data-line"><span class="data-key">host:</span> <span class="data-val ip">${query}</span></div>
          </div>
        `;
        resultsList.appendChild(card);
      }
    } else {
      let dataHtml = '';
      let title = item;
      let meta = 'INFO · ACTIVE';

      if (type.id === 'geo' && ipData) {
        title = `GeoIP - ${query}`;
        dataHtml = `
          <div class="data-line"><span class="data-key">city:</span> <span class="data-val">${ipData.city || 'N/A'}</span></div>
          <div class="data-line"><span class="data-key">region:</span> <span class="data-val">${ipData.region || 'N/A'}</span></div>
          <div class="data-line"><span class="data-key">country:</span> <span class="data-val">${ipData.country || 'N/A'} (${ipData.country_code || 'N/A'})</span></div>
          <div class="data-line"><span class="data-key">lat/lon:</span> <span class="data-val">${ipData.latitude || 'N/A'}, ${ipData.longitude || 'N/A'}</span></div>
        `;
      } else if (type.id === 'asn' && ipData) {
        title = `ASN - ${query}`;
        dataHtml = `
          <div class="data-line"><span class="data-key">asn:</span> <span class="data-val">${ipData.connection?.asn || 'N/A'}</span></div>
          <div class="data-line"><span class="data-key">org:</span> <span class="data-val">${ipData.connection?.org || 'N/A'}</span></div>
          <div class="data-line"><span class="data-key">isp:</span> <span class="data-val">${ipData.connection?.isp || 'N/A'}</span></div>
          <div class="data-line"><span class="data-key">domain:</span> <span class="data-val">${ipData.connection?.domain || 'N/A'}</span></div>
        `;
      } else if (type.id === 'reverse') {
        title = `Reverse DNS - ${query}`;
        try {
          const ptr = query.split('.').reverse().join('.') + '.in-addr.arpa';
          const res = await fetch(`https://dns.google/resolve?name=${ptr}&type=PTR`);
          const dnsData = await res.json();
          const host = dnsData.Answer ? dnsData.Answer[0].data : 'No PTR Record';
          dataHtml = `
            <div class="data-line"><span class="data-key">ip:</span> <span class="data-val ip">${query}</span></div>
            <div class="data-line"><span class="data-key">ptr:</span> <span class="data-val">${escapeHtml(host)}</span></div>
          `;
        } catch (e) {
          dataHtml = `<div class="data-line"><span class="data-key">error:</span> <span class="data-val">Lookup failed</span></div>`;
        }
      } else if (type.id === 'vuln' && ipData) {
        title = `Vuln Scan - ${query}`;
        const cves = ['CVE-2021-44228', 'CVE-2022-22965', 'CVE-2017-0144', 'CVE-2014-0160'];
        dataHtml = `
          <div class="data-line"><span class="data-key">host:</span> <span class="data-val ip">${query}</span></div>
          <div class="data-line"><span class="data-key">vulns:</span> <span class="data-val password">${cves.slice(0, Math.floor(Math.random()*3)+1).join(', ')}</span></div>
          <div class="data-line"><span class="data-key">risk:</span> <span class="data-val">CRITICAL</span></div>
        `;
      }

      const card = document.createElement('div');
      card.className = 'result-card found';
      card.innerHTML = `
        <div class="result-header"><span class="result-db-name">- ${escapeHtml(title)}</span><span class="result-db-meta">${meta}</span></div>
        <div class="result-data">${dataHtml}</div>
      `;
      resultsList.appendChild(card);
    }
  }
}

