function escapeHtml(str) {
  if (!str) return '';
  return str.replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[m]);
}

function showToast(msg, type = 'info') {
  toastText.textContent = msg;
  toast.className = 'toast show ' + type;
  clearTimeout(toast._t);
  toast._t = setTimeout(() => toast.classList.remove('show'), 3000);
}

function copyKey() {
  navigator.clipboard.writeText('sk-aurex-prod-8f7b9a3c5e1d2f4b6a8c0d2e4f6a8b0c').then(() => {
    showToast('API Key copied to clipboard', 'success');
  });
}

function updateCredits() {
  creditsVal.textContent = totalCredits.toLocaleString();
}

// ============== PRICING MODAL ==============
const modal = $('#pricingModal');
const modalClose = $('#modalClose');

function openModal() { modal.classList.add('show'); }
function closeModal() { modal.classList.remove('show'); }

 $('#creditsBtn').addEventListener('click', openModal);
 $('#accountBtn').addEventListener('click', openModal);
modalClose.addEventListener('click', closeModal);
